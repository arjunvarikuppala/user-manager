{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "Frontend/dist"
      }
    }
  ],
  "rewrites": [
    { "source": "/user-api/(.*)", "destination": "api/index.js" },
    { "source": "/health", "destination": "api/index.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
